# QUIE NFC Platform - environment variables
# Copy this file as .env and fill in the values.

# Server
PORT=3000
NODE_ENV=development
FORCE_HTTPS=false
DOMAIN=

# Aurora PostgreSQL (AWS)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
POSTGRES_HOST=HOST
POSTGRES_PORT=5432
POSTGRES_DATABASE=DBNAME
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_SSL=true

# Legacy DB_* aliases used by the current Node server if needed
DB_HOST=HOST
DB_PORT=5432
DB_NAME=quie_nfc
DB_USER=USER
DB_PASSWORD=PASSWORD

# DynamoDB (AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_TABLE_ESCANEOS=quie_escaneos

# App URLs
BASE_URL=http://localhost:3000
NEXT_PUBLIC_QUIE_BASE_URL=https://quie-nfc-platform.vercel.app

# Security
JWT_SECRET=
COOKIE_SECRET=

# Admin panel
ADMIN_USERNAME=nexo_admin
ADMIN_PASSWORD_HASH=
