# QUIE® NFC Platform — Variables de entorno
# Copia este archivo como .env y completa los valores

# Servidor
PORT=3000
NODE_ENV=development

# Aurora PostgreSQL (AWS)
DB_HOST=
DB_PORT=5432
DB_NAME=quie_nfc
DB_USER=
DB_PASSWORD=

# DynamoDB (AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_TABLE_ESCANEOS=quie_escaneos

# App
BASE_URL=http://localhost:3000
JWT_SECRET=